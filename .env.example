# ── Secrets Management ──────────────────────────────────────
# Primary: Doppler (doppler run -- docker compose up --build)
# Fallback: This .env file (docker compose up --build)
#
# If using Doppler, secrets are injected at runtime and override
# values in this file. See README.md for setup instructions.
# ────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────
# For local dev (docker compose), these defaults work as-is.
# For Railway, set DB_HOST to postgres.railway.internal and use Railway-provided credentials.
DB_HOST=postgres
DB_PORT=5432
DB_NAME=ouro
DB_USER=ouro
DB_PASSWORD=changeme

# ── LLM ──────────────────────────────────────────────────────
LLM_MODEL=openai:gpt-4o-mini
OPENAI_API_KEY=                        # Managed by Doppler

# ── Slurm ────────────────────────────────────────────────────
# Production: Run ./deploy/deploy-agent.sh — it fetches the controller IP and sets
# SLURMREST_URL automatically. No manual config needed.
# Local dev: Point to your Slurm cluster or mock.
SLURMREST_URL=http://localhost:6820
SLURMREST_JWT=                         # Managed by Doppler

# ── Blockchain (Base Mainnet) ────────────────────────────────
BASE_RPC_URL=https://mainnet.base.org
CHAIN_CAIP2=eip155:8453
CHAIN_ID=8453
WALLET_PRIVATE_KEY=                    # Managed by Doppler
WALLET_ADDRESS=                        # Managed by Doppler

# Uncomment for Base Sepolia testnet:
# BASE_RPC_URL=https://sepolia.base.org
# CHAIN_CAIP2=eip155:84532
# CHAIN_ID=84532

# ── Contracts ────────────────────────────────────────────────
USDC_CONTRACT_ADDRESS=0x...

# ── ERC-8021 Builder Code ────────────────────────────────────
BUILDER_CODE=ouro

# ── x402 Payment ─────────────────────────────────────────────
X402_FACILITATOR_URL=https://x402.org/facilitator
CDP_API_KEY_ID=                        # Managed by Doppler
CDP_API_KEY_SECRET=                    # Managed by Doppler

# ── Pricing ──────────────────────────────────────────────────
PRICE_MARGIN_MULTIPLIER=1.5

# ── Admin ─────────────────────────────────────────────────────
# Shared secret between agent and dashboard for admin endpoint access.
# Generate with: openssl rand -hex 32
# Leave empty in dev to disable auth checks (all endpoints open).
ADMIN_API_KEY=                         # Managed by Doppler

# ── Dashboard-Only Env Vars ──────────────────────────────────
# Operator wallet address — controls who sees the Admin nav link
# and can authenticate to the /admin page via wallet signature.
# (Set on the dashboard service, not the agent.)
# NEXT_PUBLIC_ADMIN_ADDRESS=0x...

# ── Public URLs (set after deployment) ───────────────────────
PUBLIC_DASHBOARD_URL=https://ourocompute.com
PUBLIC_API_URL=https://api.ourocompute.com
